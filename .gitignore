.Python
*.egg-info/

# Trainer artifacts (huge — regenerate locally).
# Exclude contents but keep the README (whitelisting requires that the parent
# directory itself isn't ignored — git won't descend into a fully-ignored dir).
trainer/data/
trainer/inputs/*
!trainer/inputs/README.md

